generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  name String
  email String @unique
  password_hash String
  created_at DateTime @default(now())

  @@map("users")
}

model Checkin {
  id String @id @default(cuid())
  created_at DateTime @default(now())
  validated_at DateTime?

  @@map("check_ins")
}

model Gym {
  id String @id @default(cuid())
  title String
  description String?
  phone String?
  latitude Decimal
  longitude Decimal

  @@map("gyms")
}
